generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  FACULTY
  ADVISOR
  ADMIN
}

enum Modality {
  ONLINE
  ON_CAMPUS
  HYBRID
}

enum EnrollmentStatus {
  CART
  ENROLLED
  WAITLISTED
  PENDING_APPROVAL
  DROPPED
  COMPLETED
}

enum HoldType {
  REGISTRATION
  ACADEMIC
  FINANCIAL
}

enum AcademicRequestType {
  CREDIT_OVERLOAD
  PREREQ_OVERRIDE
}

enum AcademicRequestStatus {
  SUBMITTED
  APPROVED
  REJECTED
  WITHDRAWN
}

enum AcademicRequestStepStatus {
  WAITING
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum AcademicRequestStepOwnerStrategy {
  DIRECT_USER
  PRIMARY_ADVISOR
  SECTION_INSTRUCTOR
  ADMIN_REVIEWER
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  studentId               String?                  @unique
  passwordHash            String
  role                    Role
  emailVerifiedAt         DateTime?
  lastLoginAt             DateTime?
  loginAttempts           Int                      @default(0)
  lockedUntil             DateTime?
  deletedAt               DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  studentProfile          StudentProfile?
  facultyProfile          FacultyProfile?
  advisorProfile          AdvisorProfile?
  issuedInviteCodes       InviteCode[]             @relation("InviteIssuer")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  enrollments             Enrollment[]             @relation("StudentEnrollments")
  cartItems               CartItem[]               @relation("StudentCartItems")
  ratings                 CourseRating[]
  notificationLogs        NotificationLog[]
  auditLogs               AuditLog[]               @relation("AuditActor")
  watches                 SectionWatch[]
  scheduleSnapshots       ScheduleSnapshot[]
  gradeAppealsAsStudent   GradeAppeal[]            @relation("StudentGradeAppeals")
  gradeAppealsAsAdmin     GradeAppeal[]            @relation("AdminGradeAppeals")
  studentNotesReceived    StudentNote[]            @relation("StudentNotesReceived")
  studentNotesWritten     StudentNote[]            @relation("StudentNotesWritten")
  createdCalendarEvents   CalendarEvent[]          @relation("CreatedCalendarEvents")
  instructedSections      Section[]                @relation("SectionInstructor")
  adviseeAssignments      AdvisorAssignment[]      @relation("StudentAdvisorAssignments")
  advisorAssignments      AdvisorAssignment[]      @relation("AdvisorAssignments")
  assignedAdvisorActions  AdvisorAssignment[]      @relation("AdvisorAssignmentActor")
  adviseeNotes            AdvisorNote[]            @relation("StudentAdvisorNotes")
  advisorNotes            AdvisorNote[]            @relation("AdvisorNotes")
  studentHolds            StudentHold[]            @relation("StudentHolds")
  createdStudentHolds     StudentHold[]            @relation("CreatedStudentHolds")
  resolvedStudentHolds    StudentHold[]            @relation("ResolvedStudentHolds")
  academicRequests        AcademicRequest[]        @relation("StudentAcademicRequests")
  ownedAcademicRequests   AcademicRequest[]        @relation("AcademicRequestOwner")
  decidedAcademicRequests AcademicRequest[]        @relation("AcademicRequestDecisionActor")
  ownedAcademicRequestSteps AcademicRequestStep[]  @relation("AcademicRequestStepOwner")
  initialAcademicRequestSteps AcademicRequestStep[] @relation("AcademicRequestStepInitialOwner")
  decidedAcademicRequestSteps AcademicRequestStep[] @relation("AcademicRequestStepDecisionActor")

  @@index([role, deletedAt])
}

model StudentProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  legalName        String
  dob              DateTime?
  address          String?
  emergencyContact String?
  programMajor     String?
  enrollmentStatus String?
  academicStatus   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FacultyProfile {
  id         String   @id @default(uuid())
  userId      String   @unique
  displayName String
  employeeId  String?  @unique
  department  String?
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdvisorProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  displayName    String
  employeeId     String?  @unique
  department     String?
  officeLocation String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdvisorAssignment {
  id               String   @id @default(uuid())
  studentId        String
  advisorId        String
  assignedByUserId String?
  active           Boolean  @default(true)
  notes            String?
  assignedAt       DateTime @default(now())
  endedAt          DateTime?
  student          User     @relation("StudentAdvisorAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  advisor          User     @relation("AdvisorAssignments", fields: [advisorId], references: [id], onDelete: Cascade)
  assignedBy       User?    @relation("AdvisorAssignmentActor", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([studentId, active])
  @@index([advisorId, active])
}

model AdvisorNote {
  id        String   @id @default(uuid())
  studentId String
  advisorId String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   User     @relation("StudentAdvisorNotes", fields: [studentId], references: [id], onDelete: Cascade)
  advisor   User     @relation("AdvisorNotes", fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([advisorId, createdAt])
}

model InviteCode {
  id             String    @id @default(uuid())
  code           String    @unique
  issuedByUserId String?
  expiresAt      DateTime?
  maxUses        Int?
  usedCount      Int       @default(0)
  usedAt         DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  issuedBy       User?     @relation("InviteIssuer", fields: [issuedByUserId], references: [id])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Term {
  id                  String       @id @default(uuid())
  name                String
  startDate           DateTime
  endDate             DateTime
  registrationOpenAt  DateTime
  registrationCloseAt DateTime
  registrationOpen    Boolean      @default(true)
  dropDeadline        DateTime
  maxCredits          Int
  timezone            String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  sections            Section[]
  enrollments         Enrollment[]
  cartItems           CartItem[]
  scheduleSnapshots   ScheduleSnapshot[]
  academicRequests    AcademicRequest[]
  calendarEvents      CalendarEvent[]
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  eventDate   DateTime
  endDate     DateTime?
  type        String    @default("INFO") // INFO | EXAM | HOLIDAY | DEADLINE | REGISTRATION
  termId      String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  term        Term?     @relation(fields: [termId], references: [id], onDelete: SetNull)
  createdBy   User      @relation("CreatedCalendarEvents", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([eventDate])
  @@index([termId, eventDate])
}

model Course {
  id                    String               @id @default(uuid())
  code                  String               @unique
  title                 String
  description           String?
  credits               Int
  weeklyHours           Float?
  deletedAt             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  sections              Section[]
  prerequisiteLinks     CoursePrerequisite[] @relation("CoursePrerequisites")
  requiredForLinks      CoursePrerequisite[] @relation("RequiredForCourses")
  pairingsA             CoursePairing[]      @relation("PairingCourseA")
  pairingsB             CoursePairing[]      @relation("PairingCourseB")
}

model CoursePrerequisite {
  id                   String @id @default(uuid())
  courseId             String
  prerequisiteCourseId String
  course               Course @relation("CoursePrerequisites", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisiteCourse   Course @relation("RequiredForCourses", fields: [prerequisiteCourseId], references: [id], onDelete: Cascade)

  @@unique([courseId, prerequisiteCourseId])
}

model Section {
  id              String       @id @default(uuid())
  termId          String
  courseId        String
  instructorUserId String?
  sectionCode     String
  modality        Modality
  capacity        Int
  credits         Int
  instructorName  String
  location        String?
  requireApproval Boolean      @default(false)
  startDate       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  term            Term         @relation(fields: [termId], references: [id], onDelete: Cascade)
  course          Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructorUser  User?        @relation("SectionInstructor", fields: [instructorUserId], references: [id], onDelete: SetNull)
  meetingTimes    MeetingTime[]
  enrollments     Enrollment[]
  cartItems       CartItem[]
  ratings         CourseRating[]
  watches         SectionWatch[]
  academicRequests AcademicRequest[]

  @@unique([termId, sectionCode])
  @@index([courseId])
  @@index([instructorUserId])
  @@index([termId])
}

model MeetingTime {
  id           String  @id @default(uuid())
  sectionId    String
  weekday      Int
  startMinutes Int
  endMinutes   Int
  section      Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id              String           @id @default(uuid())
  studentId       String
  termId          String
  sectionId       String
  status          EnrollmentStatus
  waitlistPosition Int?
  finalGrade      String?
  droppedAt       DateTime?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  student         User             @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  term            Term             @relation(fields: [termId], references: [id], onDelete: Cascade)
  section         Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  gradeAppeals    GradeAppeal[]

  @@index([studentId, termId, deletedAt])
  @@index([sectionId, status, deletedAt])
  @@index([studentId])
  @@index([sectionId])
  @@index([status])
  @@index([studentId, status])
  @@unique([sectionId, waitlistPosition])
}

model CartItem {
  id        String   @id @default(uuid())
  studentId String
  termId    String
  sectionId String
  createdAt DateTime @default(now())
  student   User     @relation("StudentCartItems", fields: [studentId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([studentId, termId, sectionId])
  @@index([studentId])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  prevIntegrityHash String?
  integrityHash     String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([createdAt])
  @@index([actorUserId])
  @@index([action])
}

model CourseRating {
  id             String   @id @default(cuid())
  studentId      String
  sectionId      String
  rating         Int
  difficulty     Int?
  workload       Int?
  wouldRecommend Boolean?
  comment        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  student        User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section        Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([studentId, sectionId])
  @@index([sectionId])
}

model CoursePairing {
  id          String   @id @default(cuid())
  courseAId   String
  courseBId   String
  coCount     Int      @default(1)
  updatedAt   DateTime @updatedAt
  courseA     Course   @relation("PairingCourseA", fields: [courseAId], references: [id], onDelete: Cascade)
  courseB     Course   @relation("PairingCourseB", fields: [courseBId], references: [id], onDelete: Cascade)

  @@unique([courseAId, courseBId])
  @@index([courseAId, coCount])
  @@index([courseBId, coCount])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  audience  String   @default("ALL")
  active    Boolean  @default(true)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@index([active, expiresAt])
  @@index([expiresAt])
  @@index([audience])
}

model NotificationLog {
  id        Int      @id @default(autoincrement())
  userId    String
  type      String
  subject   String
  body      String   @db.Text
  sentAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sentAt])
}

model StudentHold {
  id               String    @id @default(uuid())
  studentId        String
  type             HoldType
  reason           String
  note             String?   @db.Text
  active           Boolean   @default(true)
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?
  createdByUserId  String?
  resolvedByUserId String?
  student          User      @relation("StudentHolds", fields: [studentId], references: [id], onDelete: Cascade)
  createdBy        User?     @relation("CreatedStudentHolds", fields: [createdByUserId], references: [id], onDelete: SetNull)
  resolvedBy       User?     @relation("ResolvedStudentHolds", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([studentId, active, expiresAt])
  @@index([type, active])
}

model AcademicRequest {
  id                   String                @id @default(uuid())
  studentId            String
  type                 AcademicRequestType
  status               AcademicRequestStatus @default(SUBMITTED)
  activeRequestKey     String?               @unique
  currentStepOrder     Int?
  termId               String?
  sectionId            String?
  reason               String                @db.Text
  requestedCredits     Int?
  requiredApproverRole Role?
  ownerUserId          String?
  submittedAt          DateTime              @default(now())
  decisionAt           DateTime?
  decisionNote         String?               @db.Text
  decidedByUserId      String?
  updatedAt            DateTime              @updatedAt
  student              User                  @relation("StudentAcademicRequests", fields: [studentId], references: [id], onDelete: Cascade)
  term                 Term?                 @relation(fields: [termId], references: [id], onDelete: SetNull)
  section              Section?              @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  owner                User?                 @relation("AcademicRequestOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  decidedBy            User?                 @relation("AcademicRequestDecisionActor", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  steps                AcademicRequestStep[]

  @@index([studentId, status])
  @@index([ownerUserId, status])
  @@index([termId, type, status])
  @@index([sectionId, type, status])
}

model AcademicRequestStep {
  id                   String                    @id @default(uuid())
  requestId            String
  stepOrder            Int
  stepKey              String
  label                String
  requiredApproverRole Role
  ownerStrategy        AcademicRequestStepOwnerStrategy @default(DIRECT_USER)
  ownerResolutionRefId String?
  ownerResolvedAt      DateTime?
  initialOwnerUserId   String?
  ownerUserId          String?
  status               AcademicRequestStepStatus @default(WAITING)
  decisionNote         String?                   @db.Text
  decidedByUserId      String?
  decidedAt            DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  request              AcademicRequest           @relation(fields: [requestId], references: [id], onDelete: Cascade)
  initialOwner         User?                     @relation("AcademicRequestStepInitialOwner", fields: [initialOwnerUserId], references: [id], onDelete: SetNull)
  owner                User?                     @relation("AcademicRequestStepOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  decidedBy            User?                     @relation("AcademicRequestStepDecisionActor", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@unique([requestId, stepOrder])
  @@index([ownerStrategy, status])
  @@index([initialOwnerUserId])
  @@index([ownerUserId, status])
  @@index([requiredApproverRole, status])
}

model SectionWatch {
  id         String   @id @default(cuid())
  userId     String
  sectionId  String
  createdAt  DateTime @default(now())
  notifiedAt DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
}

model ScheduleSnapshot {
  id           String   @id @default(cuid())
  studentId    String
  termId       String
  sectionsJson String   @db.Text
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term         Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([termId])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model GradeAppeal {
  id               String    @id @default(cuid())
  studentId        String
  enrollmentId     String
  contestedGrade   String
  requestedGrade   String?
  reason           String    @db.Text
  status           String    @default("PENDING") // PENDING | APPROVED | REJECTED
  adminNote        String?   @db.Text
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  student          User      @relation("StudentGradeAppeals", fields: [studentId], references: [id], onDelete: Cascade)
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  reviewedBy       User?     @relation("AdminGradeAppeals", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([studentId, status])
  @@index([status, createdAt])
}

model StudentNote {
  id        String   @id @default(cuid())
  studentId String
  adminId   String
  content   String   @db.Text
  flag      String?  // "urgent" | "academic" | "financial" | "positive" | null
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   User     @relation("StudentNotesReceived", fields: [studentId], references: [id], onDelete: Cascade)
  admin     User     @relation("StudentNotesWritten", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}
