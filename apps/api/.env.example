DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sis_db?schema=public"
JWT_SECRET=   # 必填：openssl rand -base64 64
WEB_URL="http://localhost:3000"
API_PORT=4000
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=8
LOGIN_RATE_LIMIT_LOCK_MS=900000
PASSWORD_RESET_TOKEN_TTL_MS=1800000
CSRF_ALLOWED_ORIGINS="http://localhost:3000"
CSRF_COOKIE_NAME="sis-csrf"
CSRF_HEADER_NAME="x-csrf-token"
NEXT_PUBLIC_CSRF_COOKIE_NAME="sis-csrf"
NEXT_PUBLIC_CSRF_HEADER_NAME="x-csrf-token"
CSRF_EXEMPT_PATHS="/auth/login,/auth/register,/auth/forgot-password,/auth/reset-password"
COOKIE_SAME_SITE="lax"
COOKIE_SECURE=false
COOKIE_DOMAIN=""
ALERT_CSRF_ORIGIN_BLOCKED_THRESHOLD=5
ALERT_CSRF_TOKEN_INVALID_THRESHOLD=20
ALERT_LOGIN_RATE_LIMITED_THRESHOLD=10
ALERT_HTTP_ERROR_RATE_PERCENT=5
ALERT_MAIL_DELIVERY_FAILED_THRESHOLD=3
ADMIN_PERMISSION_DEFAULT_ALLOW=true
SUPERADMIN_USER_IDS=""
ADMIN_PERMISSION_OVERRIDES=""
DATABASE_REPLICA_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
SAML_ENTRY_POINT=https://idp.youruniversity.edu/saml2/sso
SAML_ISSUER=sis-production
SAML_IDP_CERT=
