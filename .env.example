# 地平线 SIS 环境变量模板
# 用法：
#   cp .env.example apps/api/.env
#   cp .env.example apps/web/.env.local
# 然后按需修改下方值。

# DATABASE_URL：API 连接 PostgreSQL 的完整连接串。
DATABASE_URL="postgresql://sis:sis_dev_pass@localhost:5432/horizon_sis?schema=public"

# JWT_SECRET：JWT 签名密钥；生产环境必须替换为强随机长字符串。
JWT_SECRET="change_me_in_production"

# PASSWORD_RESET_TOKEN_TTL_MS：密码重置令牌有效期（毫秒）。
PASSWORD_RESET_TOKEN_TTL_MS=1800000

# AUTH_EXPOSE_DEBUG_LINKS：是否在开发环境暴露调试用链接。
AUTH_EXPOSE_DEBUG_LINKS=false

# MAIL_ENABLED：是否显式启用邮件发送；未配 SMTP 时建议保持 false。
MAIL_ENABLED=false

# SMTP_HOST：SMTP 服务器地址；留空表示开发态不实际发送。
SMTP_HOST=""

# SMTP_PORT：SMTP 服务器端口。
SMTP_PORT=587

# SMTP_SECURE：SMTP 是否使用 TLS/SSL 直连。
SMTP_SECURE=false

# SMTP_USER：SMTP 用户名。
SMTP_USER=""

# SMTP_PASS：SMTP 密码或授权码。
SMTP_PASS=""

# SMTP_FROM：系统发件人地址。
SMTP_FROM="noreply@horizon-sis.local"

# WEB_URL：前端对外访问地址，供 API 生成回调链接和 CORS 校验使用。
WEB_URL="http://localhost:3000"

# PORT：NestJS API 监听端口。
PORT=4000

# API_PORT：Docker / 监控脚本使用的 API 对外端口。
API_PORT=4000

# NEXT_PUBLIC_API_URL：浏览器端访问 API 的基础地址。
NEXT_PUBLIC_API_URL="http://localhost:4000"

# NGINX_HTTP_PORT：反向代理容器暴露的 HTTP 端口。
NGINX_HTTP_PORT=80

# SIS_TIMEZONE：系统默认时区，用于学期窗口和日历展示。
SIS_TIMEZONE="America/Los_Angeles"

# ENABLE_PUBLIC_SCHEDULE_SHARING：是否允许公开课表分享。
ENABLE_PUBLIC_SCHEDULE_SHARING=false

# NEXT_PUBLIC_ENABLE_PUBLIC_SCHEDULE_SHARING：前端是否展示公开课表分享入口。
NEXT_PUBLIC_ENABLE_PUBLIC_SCHEDULE_SHARING=false

# NEXT_PUBLIC_CSRF_COOKIE_NAME：前端读取的 CSRF Cookie 名称。
NEXT_PUBLIC_CSRF_COOKIE_NAME="sis-csrf"

# NEXT_PUBLIC_CSRF_HEADER_NAME：前端发送的 CSRF Header 名称。
NEXT_PUBLIC_CSRF_HEADER_NAME="x-csrf-token"

# CSRF_ALLOWED_ORIGINS：允许提交敏感请求的前端来源。
CSRF_ALLOWED_ORIGINS="http://localhost:3000"

# CSRF_COOKIE_NAME：API 写入的 CSRF Cookie 名称，需与前端保持一致。
CSRF_COOKIE_NAME="sis-csrf"

# CSRF_HEADER_NAME：API 校验的 CSRF Header 名称，需与前端保持一致。
CSRF_HEADER_NAME="x-csrf-token"

# CSRF_EXEMPT_PATHS：免除 CSRF 校验的认证相关路径。
CSRF_EXEMPT_PATHS="/auth/login,/auth/register,/auth/forgot-password,/auth/reset-password"

# COOKIE_SAME_SITE：认证 Cookie 的 SameSite 策略。
COOKIE_SAME_SITE="lax"

# COOKIE_SECURE：是否只通过 HTTPS 发送 Cookie。
COOKIE_SECURE=false

# COOKIE_DOMAIN：认证 Cookie 的域名作用范围；本地开发通常留空。
COOKIE_DOMAIN=""

# ALERT_CSRF_ORIGIN_BLOCKED_THRESHOLD：CSRF origin 被阻止达到多少次后触发告警。
ALERT_CSRF_ORIGIN_BLOCKED_THRESHOLD=5

# ALERT_CSRF_TOKEN_INVALID_THRESHOLD：CSRF token 失效达到多少次后触发告警。
ALERT_CSRF_TOKEN_INVALID_THRESHOLD=20

# ALERT_LOGIN_RATE_LIMITED_THRESHOLD：登录被限流达到多少次后触发告警。
ALERT_LOGIN_RATE_LIMITED_THRESHOLD=10

# ALERT_HTTP_ERROR_RATE_PERCENT：HTTP 错误率超过多少百分比后触发告警。
ALERT_HTTP_ERROR_RATE_PERCENT=5

# ALERT_MAIL_DELIVERY_FAILED_THRESHOLD：邮件发送失败达到多少次后触发告警。
ALERT_MAIL_DELIVERY_FAILED_THRESHOLD=3

# ADMIN_PERMISSION_DEFAULT_ALLOW：开发环境是否默认放开 admin 权限。
ADMIN_PERMISSION_DEFAULT_ALLOW=true

# SUPERADMIN_USER_IDS：超级管理员用户 ID 列表，逗号分隔。
SUPERADMIN_USER_IDS=""

# ADMIN_PERMISSION_OVERRIDES：按用户粒度覆盖 admin 权限的 JSON 字符串。
ADMIN_PERMISSION_OVERRIDES=""

# POSTGRES_USER：Docker PostgreSQL 用户名。
POSTGRES_USER=sis

# POSTGRES_PASSWORD：Docker PostgreSQL 密码。
POSTGRES_PASSWORD=sis_dev_pass

# POSTGRES_DB：Docker PostgreSQL 数据库名。
POSTGRES_DB=horizon_sis

# WEB_PORT：Docker Web 服务对外端口。
WEB_PORT=3000

# BACKUP_SCHEDULE：自动备份 cron 表达式。
BACKUP_SCHEDULE="@daily"

# BACKUP_KEEP_DAYS：按天保留的备份数量。
BACKUP_KEEP_DAYS=7

# BACKUP_KEEP_WEEKS：按周保留的备份数量。
BACKUP_KEEP_WEEKS=4

# BACKUP_KEEP_MONTHS：按月保留的备份数量。
BACKUP_KEEP_MONTHS=6

# GRAFANA_ADMIN_USER：Grafana 管理员用户名。
GRAFANA_ADMIN_USER=admin

# GRAFANA_ADMIN_PASSWORD：Grafana 管理员密码。
GRAFANA_ADMIN_PASSWORD=sis-grafana-2026

# GRAFANA_ROOT_URL：Grafana 对外访问地址。
GRAFANA_ROOT_URL=http://localhost:3001

# ALERT_EMAIL：接收告警邮件的默认地址。
ALERT_EMAIL=admin@univ.edu

# NEXT_PUBLIC_APP_VERSION：前端显示的应用版本号。
NEXT_PUBLIC_APP_VERSION=v1.0.0

# NEXT_PUBLIC_BUILD_TIME：前端显示的构建时间；CI/CD 可注入。
NEXT_PUBLIC_BUILD_TIME=

# NEXT_PUBLIC_GRAFANA_URL：前端跳转 Grafana 的地址。
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001

# THROTTLE_TTL：全局限流时间窗（秒）。
THROTTLE_TTL=60

# THROTTLE_LIMIT：全局限流窗口内允许的最大请求数。
THROTTLE_LIMIT=100

# THROTTLE_AUTH_LIMIT：认证相关接口更严格的限流阈值。
THROTTLE_AUTH_LIMIT=5
