# ================================================================
# 地平线 SIS — 环境变量说明
# 复制本文件为 .env 并填写所有必填项后启动服务
# 生产部署前必填：DATABASE_URL, JWT_SECRET, SMTP_*, CORS_ORIGIN
# ================================================================

# --- 数据库 ---
# DATABASE_URL=postgresql://user:pass@host:5432/sis
# 本地开发（直连 PostgreSQL）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sis_db?schema=public"

# Docker Compose 内部用 (docker-compose.yml 自动注入, 不需手动修改)
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/sis_db?schema=public"

# --- JWT ---
# JWT_SECRET 生产环境必须使用强随机值（≥32 字节）
# JWT_EXPIRES_IN 默认 7d，生产建议 1d
# ⚠️  生产环境必须换成随机长字符串，例如:
#     openssl rand -hex 32
JWT_SECRET="change-me"
PASSWORD_RESET_TOKEN_TTL_MS=1800000
AUTH_EXPOSE_DEBUG_LINKS=false

# --- SMTP 邮件 ---
# 不配置则邮件静默（no-op），功能不受影响但不发送邮件
# 开关: 未配置 SMTP 时自动禁用；设置 true 可强制启用（需完整 SMTP 参数）
MAIL_ENABLED=false
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@horizon-sis.local"

# --- 服务地址 ---
# 本地开发
WEB_URL="http://localhost:3000"
API_PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"
NGINX_HTTP_PORT=80

# --- CSRF ---
# CSRF_COOKIE_NAME 与 NEXT_PUBLIC_CSRF_COOKIE_NAME 必须保持一致
NEXT_PUBLIC_CSRF_COOKIE_NAME="sis-csrf"
NEXT_PUBLIC_CSRF_HEADER_NAME="x-csrf-token"
CSRF_ALLOWED_ORIGINS="http://localhost:3000"
CSRF_COOKIE_NAME="sis-csrf"
CSRF_HEADER_NAME="x-csrf-token"
CSRF_EXEMPT_PATHS="/auth/login,/auth/register,/auth/forgot-password,/auth/reset-password"
COOKIE_SAME_SITE="lax"
COOKIE_SECURE=false
COOKIE_DOMAIN=""
ALERT_CSRF_ORIGIN_BLOCKED_THRESHOLD=5
ALERT_CSRF_TOKEN_INVALID_THRESHOLD=20
ALERT_LOGIN_RATE_LIMITED_THRESHOLD=10
ALERT_HTTP_ERROR_RATE_PERCENT=5
ALERT_MAIL_DELIVERY_FAILED_THRESHOLD=3

# --- 管理端权限（RBAC） ---
# 生产建议:
# ADMIN_PERMISSION_DEFAULT_ALLOW=false
# SUPERADMIN_USER_IDS="<uuid1>,<uuid2>"
# ADMIN_PERMISSION_OVERRIDES='{\"<adminUserId>\":[\"dashboard:read\",\"terms:read\",\"enrollments:write\"]}'
ADMIN_PERMISSION_DEFAULT_ALLOW=true
SUPERADMIN_USER_IDS=""
ADMIN_PERMISSION_OVERRIDES=""

# 云服务器部署时，改为你的服务器 IP 或域名，例如:
# WEB_URL="http://1.2.3.4:3000"
# NEXT_PUBLIC_API_URL="http://1.2.3.4:4000"

# --- Docker Compose 数据库配置 ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sis_db
WEB_PORT=3000

# --- 备份 ---
# BACKUP_SCHEDULE cron 格式，默认每天 2:30 AM
BACKUP_SCHEDULE="@daily"
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# --- 监控 ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=sis-grafana-2026
GRAFANA_ROOT_URL=http://localhost:3001
ALERT_EMAIL=admin@sis.edu
NEXT_PUBLIC_APP_VERSION=v1.0.0
NEXT_PUBLIC_BUILD_TIME=
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001

# --- 限流 ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=5
